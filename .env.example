# OpenClaw 本地配置示例
# 使用方式：复制为 .env，然后填入你自己的真实配置。不要把 .env 提交到仓库。

# MySQL
# 第一次运行前请先创建数据库：
# mysql -u root -p < docs/sql/create_database.sql
# 业务表不需要手动创建，项目启动时 Flyway 会自动执行 src/main/resources/db/migration 下的迁移脚本。
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/openclaw?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=
FLYWAY_ENABLED=true

# Agent 模式
# prompt-json：旧版 JSON 规划模式
# function-calling：新版标准 Function Calling Agent Loop
AGENT_TOOL_CALLING_MODE=function-calling
AGENT_TOOL_CALLING_MAX_LOOP_ROUNDS=5

# 微信登录页面
# 默认由本机随机端口提供登录页；只有经过反向代理部署时才需要设置 BASE_URL。
WECHAT_LOGIN_SERVER_ADDRESS=127.0.0.1
WECHAT_LOGIN_SERVER_PORT=0
# WECHAT_LOGIN_PAGE_BASE_URL=https://your-login-domain.example.com
WECHAT_LOGIN_SESSION_TTL=10m

# 微信记忆
WECHAT_MEMORY_SESSION_IDLE_MINUTES=60
WECHAT_MEMORY_RAW_RETENTION_DAYS=30
WECHAT_MEMORY_RECENT_TURN_LIMIT=10
WECHAT_MEMORY_ROLLING_SUMMARY_TURN_THRESHOLD=20

# 高德天气
AMAP_WEATHER_KEY=
AMAP_WEATHER_BASE_URL=https://restapi.amap.com

# 高德地图工具
# 可以与 AMAP_WEATHER_KEY 使用同一个已开通 Web 服务的 Key；留空时项目会自动复用天气 Key。
AMAP_MAP_KEY=
AMAP_MAP_BASE_URL=https://restapi.amap.com

# 阿里百炼 / DashScope 通用配置
# 注意：DASHSCOPE_BASE_URL 和 DASHSCOPE_IMAGE_BASE_URL 是每个合作者自己的模型服务地址，需要放在 .env 中。
# 示例格式：
# DASHSCOPE_BASE_URL=https://你的百炼工作空间Host/compatible-mode/v1
# DASHSCOPE_IMAGE_BASE_URL=https://你的百炼工作空间Host/api/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
DASHSCOPE_CHAT_MODEL=qwen3.7-max-2026-06-08
DASHSCOPE_ENABLE_THINKING=true

# 视觉理解 / 图片生成
DASHSCOPE_VISION_MODEL=qwen3.7-plus
DASHSCOPE_IMAGE_BASE_URL=
DASHSCOPE_IMAGE_MODEL=qwen-image-2.0-pro
DASHSCOPE_IMAGE_SIZE=1024*1024
DASHSCOPE_IMAGE_WATERMARK=false
DASHSCOPE_IMAGE_PROMPT_EXTEND=true
IMAGE_OUTPUT_DIR=generated-images

# 语音识别 / 语音合成
# 语音识别默认复用 DASHSCOPE_BASE_URL；如果你的 ASR 服务地址不同，再取消下一行注释并单独填写。
# DASHSCOPE_VOICE_BASE_URL=https://你的语音识别Host/compatible-mode/v1
DASHSCOPE_VOICE_MODEL=qwen3-asr-flash
DASHSCOPE_VOICE_MAX_POLL_ATTEMPTS=20
DASHSCOPE_VOICE_POLL_INTERVAL_MS=1000
DASHSCOPE_TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=Cherry
DASHSCOPE_TTS_FORMAT=mp3
VOICE_TTS_MAX_WECHAT_DURATION_MS=58000
VOICE_TTS_SAMPLE_RATE=16000
VOICE_TTS_ESTIMATED_CHARS_PER_SECOND=4.0
AUDIO_FFMPEG_PATH=ffmpeg
AUDIO_FFMPEG_ENABLED=true
AUDIO_FFMPEG_TIMEOUT_SECONDS=20

# 日志
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_WECHAT=INFO
LOGGING_LEVEL_WECHAT_BOT=DEBUG
LOGGING_LEVEL_WECHAT_CONVERSATION=DEBUG
LOGGING_LEVEL_ILINK=INFO
